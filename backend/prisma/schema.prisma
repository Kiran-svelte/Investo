// ─── AI Settings ────────────────────────────────────────────────────
model AiSetting {
  id                  String       @id @default(uuid()) @db.Uuid
  companyId           String       @unique @map("company_id") @db.Uuid
  businessName        String?      @map("business_name") @db.VarChar(255)
  businessDescription String?      @map("business_description") @db.Text
  operatingLocations  Json         @default("[]") @map("operating_locations")
  budgetRanges        Json         @default("{}") @map("budget_ranges")
  responseTone        ResponseTone @default(friendly) @map("response_tone")
  workingHours        Json         @default("{}") @map("working_hours")
  faqKnowledge        Json         @default("[]") @map("faq_knowledge")
  greetingTemplate    String?      @map("greeting_template") @db.Text
  /// JSON array: hero image + brochure PDF sent with first-contact WhatsApp greeting.
  greetingMedia       Json         @default("[]") @map("greeting_media")
  persuasionLevel     Int          @default(7) @map("persuasion_level")
  autoDetectLanguage  Boolean      @default(true) @map("auto_detect_language")
  defaultLanguage     String       @default("en") @map("default_language") @db.VarChar(5)

  // ─── Never-Say-No Company Brain ────────────────────────────────────
  /// Business model: residential_sale | rental | mixed | commercial | fractional
  businessType        String       @default("mixed") @map("business_type") @db.VarChar(50)
  /// JSON: partner company IDs within Investo (for cross-referral)
  partnerCompanyIds   Json         @default("[]") @map("partner_company_ids")
  /// JSON: current special offers/schemes injected into AI prompt
  specialOffers       Json         @default("[]") @map("special_offers")
  /// JSON: custom fallback rules e.g. [{"trigger":"no_inventory","action":"offer_fractional"}]
  conversionRules     Json         @default("[]") @map("conversion_rules")
  /// Weeks until next inventory launch (used for pre-launch waitlist offer)
  launchWeeksFromNow  Int?         @map("launch_weeks_from_now")
  /// Human escalation contact (name + phone shown to AI when escalating)
  operatorContact     Json         @default("{}") @map("operator_contact")
  /// Whether to offer fractional ownership when budget is below threshold
  offerFractional     Boolean      @default(true) @map("offer_fractional")
  /// Whether to offer rent-to-own when rental company gets buy request
  offerRentToOwn      Boolean      @default(true) @map("offer_rent_to_own")
  /// Budget stretch percentage (default 15%)
  budgetStretchPct    Int          @default(15) @map("budget_stretch_pct")
  /// Whether to auto-confirm visits booked via WhatsApp buttons without agent approval.
  /// Default is FALSE — agents must approve via WhatsApp interactive button.
  /// Previously controlled by WHATSAPP_AUTO_CONFIRM_VISITS env var (undocumented).
  autoConfirmVisits   Boolean      @default(false) @map("auto_confirm_visits")
  /// Optional custom name for the AI assistant persona shown to customers.
  agentName           String       @default("Riya") @map("agent_name") @db.VarChar(50)

  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("ai_settings")
}

