// ─── Workflow Run Records (saga tracking + step-level idempotency) ───
/// Tracks each workflow execution start-to-finish for observability and
/// compensating saga rollback. One record per workflow invocation.
model WorkflowRunRecord {
  id              String              @id @default(uuid()) @db.Uuid
  companyId       String              @map("company_id") @db.Uuid
  workflowId      String              @map("workflow_id") @db.VarChar(60)
  channel         String              @db.VarChar(20)
  /// Idempotency key that claimed this run (links to WorkflowIdempotencyKey).
  idempotencyKey  String?             @map("idempotency_key") @db.VarChar(255)
  status          WorkflowRunStatus   @default(running)
  /// JSON snapshot of leadId, visitId, oldStatus captured before mutations.
  stateSnapshot   Json                @default("{}") @map("state_snapshot")
  /// JSON array of {action, status, errorMessage} for each executed step.
  stepsJson       Json                @default("[]") @map("steps_json")
  failedStep      String?             @map("failed_step") @db.VarChar(80)
  completedAt     DateTime?           @map("completed_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([companyId, workflowId, createdAt])
  @@index([idempotencyKey])
  @@map("workflow_run_records")
}

/// Intent-level idempotency keys for workflow executions.
/// Prevents double-booking from two devices or duplicate WhatsApp retries.
model WorkflowIdempotencyKey {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  /// Deterministic key: {workflowId}:{companyId}:{leadId/visitId}:{scheduledAtISO}
  key         String   @db.VarChar(255)
  workflowId  String   @map("workflow_id") @db.VarChar(60)
  /// Cached reply to return on duplicate claim (avoids re-running the LLM).
  resultReply String?  @map("result_reply") @db.Text
  status      String   @default("completed") @db.VarChar(20)
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@index([companyId, expiresAt])
  @@map("workflow_idempotency_keys")
}

// ─── Agent Action Log (AI transparency + audit trail) ────────────────
model AgentActionLog {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  /// Who triggered the action: cron, agent_tool, automation, or inbound_message
  triggeredBy  String   @map("triggered_by") @db.VarChar(40)
  /// userId of the team member if triggered by an agent tool call; null for cron/automation
  actorId      String?  @map("actor_id") @db.Uuid
  actorRole    String?  @map("actor_role") @db.VarChar(40)
  /// Name of the action or tool (e.g. rescheduleVisit, sendFollowUp, detectNoShow)
  action       String   @db.VarChar(100)
  resourceType String?  @map("resource_type") @db.VarChar(40)
  resourceId   String?  @map("resource_id") @db.Uuid
  /// Tool inputs or trigger payload stored as JSON for replay/debug
  inputs       Json?    @default("{}")
  /// Human-readable summary of what the action produced
  result       String?  @db.Text
  /// success | failed | skipped
  status       String   @default("success") @db.VarChar(20)
  errorMessage String?  @map("error_message") @db.Text
  durationMs   Int?     @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, action])
  @@index([resourceType, resourceId])
  @@map("agent_action_logs")
}

