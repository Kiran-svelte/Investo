generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector", schema: "public"), uuidOssp(map: "uuid-ossp")]
}

// ─── Subscription Plans ─────────────────────────────────────────────
model SubscriptionPlan {
  id             String    @id @default(uuid()) @db.Uuid
  name           String    @db.VarChar(100)
  maxAgents      Int       @map("max_agents")
  maxLeads       Int?      @map("max_leads")
  maxProperties  Int?      @map("max_properties")
  priceMonthly   Decimal   @map("price_monthly") @db.Decimal(12, 2)
  priceYearly    Decimal?  @map("price_yearly") @db.Decimal(12, 2)
  features       Json      @default("[]")
  status         PlanStatus @default(active)
  createdAt      DateTime  @default(now()) @map("created_at")

  companies Company[]

  @@map("subscription_plans")
}

// ─── Companies (Tenants) ────────────────────────────────────────────
model Company {
  id             String        @id @default(uuid()) @db.Uuid
  name           String        @db.VarChar(255)
  slug           String        @unique @db.VarChar(100)
  whatsappPhone  String?       @unique @map("whatsapp_phone") @db.VarChar(20)
  planId         String?       @map("plan_id") @db.Uuid
  status         CompanyStatus @default(active)
  settings       Json          @default("{}")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  plan           SubscriptionPlan? @relation(fields: [planId], references: [id])
  users          User[]
  leads          Lead[]
  properties     Property[]
  conversations  Conversation[]
  visits         Visit[]
  aiSettings     AiSetting?
  notifications  Notification[]
  auditLogs      AuditLog[]
  analytics      Analytics[]
  companyRoles   CompanyRole[]
  companyFeatures CompanyFeature[]
  onboarding     CompanyOnboarding?
  invoices       Invoice[]
  propertyProjects     PropertyProject[]
  propertyProjectFiles PropertyProjectFile[]
  propertyImportDrafts PropertyImportDraft[]
  propertyImportUnits  PropertyImportUnit[]
  propertyImportMedia  PropertyImportMedia[]
  propertyImportJobs   PropertyImportJob[]
  propertyImportMediaBlobs PropertyImportMediaBlob[]
  agentSessions            AgentSession[]
  agentActionLogs          AgentActionLog[]
  inboundWhatsappDedups    InboundWhatsappDedup[]
  whatsappJobs             WhatsAppJob[]
  whatsappDeadLetters      WhatsAppDeadLetter[]
  workflowRunRecords       WorkflowRunRecord[]
  workflowIdempotencyKeys  WorkflowIdempotencyKey[]
  quotaOverride            CompanyQuotaOverride?
  tenantUsageDaily         TenantUsageDaily[]
  identityConfig           CompanyIdentityConfig?
  branches                 CompanyBranch[]
  scimProvisioningEvents   ScimProvisioningEvent[]
  encryptedFields          EncryptedField[]
  dataSubjectRequests      DataSubjectRequest[]
  retentionPolicy          RetentionPolicy?
  legalHolds               LegalHold[]
  dpaAcceptances           DpaAcceptance[]
  outboxEvents             OutboxEvent[]
  apiKeys                  ApiKey[]
  webhookSubscriptions     WebhookSubscription[]
  usageInvoices            UsageInvoice[]
  supportImpersonations    SupportImpersonation[]
  tenantHealthScores       TenantHealthScore[]
  sandboxTenant            SandboxTenant?
  aiReviewQueueItems       AiReviewQueueItem[]
  messageArchives          MessageArchive[]
  subscription             CompanySubscription?
  agencyInvites            AgencyInvite[]
  payments                 Payment[]
  billingEvents            BillingEvent[]

  @@map("companies")
}

model CompanyQuotaOverride {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @unique @map("company_id") @db.Uuid
  quotas    Json      @default("{}")
  reason    String?   @db.Text
  expiresAt DateTime? @map("expires_at")
  createdBy String    @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_quota_overrides")
}

model TenantUsageDaily {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  date      DateTime @db.Date
  metrics   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
  @@index([date])
  @@map("tenant_usage_daily")
}

model CompanyIdentityConfig {
  id               String   @id @default(uuid()) @db.Uuid
  companyId        String   @unique @map("company_id") @db.Uuid
  ssoEnabled       Boolean  @default(false) @map("sso_enabled")
  ssoProvider      String?  @map("sso_provider") @db.VarChar(50)
  ssoConnectionId  String?  @map("sso_connection_id") @db.VarChar(255)
  ssoOidcIssuer    String?  @map("sso_oidc_issuer") @db.VarChar(500)
  ssoOidcClientId  String?  @map("sso_oidc_client_id") @db.VarChar(255)
  ssoOidcClientSecretEnc String? @map("sso_oidc_client_secret_enc") @db.Text
  scimEnabled      Boolean  @default(false) @map("scim_enabled")
  scimTokenHash    String?  @map("scim_token_hash") @db.VarChar(255)
  mfaRequired      Boolean  @default(false) @map("mfa_required")
  mfaMethods       Json     @default("[\"totp\"]") @map("mfa_methods")
  allowedDomains   Json     @default("[]") @map("allowed_domains")
  ipAllowlistEnabled Boolean @default(false) @map("ip_allowlist_enabled")
  ipAllowlist      Json     @default("[]") @map("ip_allowlist")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_identity_configs")
}

model UserMfaDevice {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  method       String   @db.VarChar(20)
  secretEnc    String?  @map("secret_enc") @db.Text
  webauthnCred Json?    @map("webauthn_cred")
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, method])
  @@map("user_mfa_devices")
}

model CompanyBranch {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String   @db.VarChar(255)
  parentId  String?  @map("parent_id") @db.Uuid
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   CompanyBranch?  @relation("BranchHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children CompanyBranch[] @relation("BranchHierarchy")
  users    User[]

  @@index([companyId])
  @@index([companyId, parentId])
  @@map("company_branches")
}

model ScimProvisioningEvent {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  action    String   @db.VarChar(50)
  externalId String? @map("external_id") @db.VarChar(255)
  userId    String?  @map("user_id") @db.Uuid
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@map("scim_provisioning_events")
}

model EncryptedField {
  id         String @id @default(uuid()) @db.Uuid
  companyId  String @map("company_id") @db.Uuid
  entityType String @map("entity_type") @db.VarChar(50)
  entityId   String @map("entity_id") @db.Uuid
  fieldName  String @map("field_name") @db.VarChar(100)
  ciphertext String @db.Text
  keyVersion Int    @default(1) @map("key_version")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, fieldName])
  @@index([companyId, entityType])
  @@map("encrypted_fields")
}

model SecretRotationLog {
  id         String   @id @default(uuid()) @db.Uuid
  secretName String   @map("secret_name") @db.VarChar(100)
  rotatedAt  DateTime @default(now()) @map("rotated_at")
  rotatedBy  String   @map("rotated_by") @db.VarChar(100)

  @@index([secretName, rotatedAt])
  @@map("secret_rotation_logs")
}

// ─── Users ──────────────────────────────────────────────────────────
model User {
  id                String     @id @default(uuid()) @db.Uuid
  authProviderId    String?    @unique @map("auth_provider_id") @db.VarChar(255)
  companyId         String     @map("company_id") @db.Uuid
  name              String     @db.VarChar(255)
  email             String     @unique @db.VarChar(255)
  phone             String?    @db.VarChar(20)
  passwordHash      String?    @map("password_hash") @db.VarChar(255)
  role              UserRole   @default(viewer)
  status            UserStatus @default(active)
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  branchId          String?    @map("branch_id") @db.Uuid
  authProvider      String     @default("local") @map("auth_provider") @db.VarChar(20)
  externalId        String?    @map("external_id") @db.VarChar(255)
  lastLogin         DateTime?  @map("last_login")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  company             Company    @relation(fields: [companyId], references: [id])
  branch              CompanyBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  mfaDevices          UserMfaDevice[]
  assignedLeads       Lead[]     @relation("AgentLeads")
  visits              Visit[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  customRole          CompanyRole? @relation(fields: [customRoleId], references: [id])
  customRoleId        String?      @map("custom_role_id") @db.Uuid
  createdPropertyImportDrafts PropertyImportDraft[] @relation("PropertyImportCreatedBy")
  reviewedPropertyImportDrafts PropertyImportDraft[] @relation("PropertyImportReviewedBy")
  agentSessions       AgentSession[]
  agentActionLogs     AgentActionLog[]

  @@index([companyId, role])
  @@unique([companyId, externalId])
  @@map("users")
}

// ─── Agent Sessions (WhatsApp AI for internal users) ────────────────
model AgentSession {
  id           String             @id @default(uuid()) @db.Uuid
  userId       String             @map("user_id") @db.Uuid
  companyId    String             @map("company_id") @db.Uuid
  phone        String             @db.VarChar(20)
  threadId     String             @unique @map("thread_id") @db.VarChar(100)
  status       AgentSessionStatus @default(active)
  lastActiveAt DateTime           @default(now()) @map("last_active_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  user          User            @relation(fields: [userId], references: [id])
  company       Company         @relation(fields: [companyId], references: [id])
  pendingActions PendingAction[]

  @@unique([userId, phone])
  @@index([phone])
  @@index([companyId, status])
  @@map("agent_sessions")
}

// ─── Pending Confirmations ──────────────────────────────────────────
model PendingAction {
  id             String              @id @default(uuid()) @db.Uuid
  sessionId      String              @map("session_id") @db.Uuid
  actionType     String              @map("action_type") @db.VarChar(100)
  actionParams   Json                @map("action_params") @default("{}")
  displayMessage String              @map("display_message") @db.Text
  status         PendingActionStatus @default(awaiting)
  expiresAt      DateTime            @map("expires_at")
  resolvedAt     DateTime?           @map("resolved_at")
  createdAt      DateTime            @default(now()) @map("created_at")

  session AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([expiresAt])
  @@map("pending_actions")
}

// ─── Refresh Tokens ─────────────────────────────────────────────────
model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime @map("expires_at")
  revoked    Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ─── Password Reset Tokens ──────────────────────────────────────────
model PasswordResetToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime @map("expires_at")
  used       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Invoices ─────────────────────────────────────────────────────────
model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  companyId      String        @map("company_id") @db.Uuid
  invoiceNumber  String        @unique @map("invoice_number") @db.VarChar(50)
  amount         Decimal       @db.Decimal(12, 2)
  tax            Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal       @map("total_amount") @db.Decimal(12, 2)
  currency       String        @default("INR") @db.VarChar(3)
  status         InvoiceStatus @default(pending)
  periodStart    DateTime      @map("period_start")
  periodEnd      DateTime      @map("period_end")
  dueDate        DateTime      @map("due_date")
  paidAt         DateTime?     @map("paid_at")
  paymentMethod  String?       @map("payment_method") @db.VarChar(50)
  paymentRef     String?       @map("payment_ref") @db.VarChar(100)
  notes          String?       @db.Text
  lineItems      Json          @default("[]") @map("line_items")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  company        Company       @relation(fields: [companyId], references: [id])
  payments       Payment[]

  @@index([companyId, status])
  @@index([dueDate])
  @@map("invoices")
}

// ─── Company Subscription (billing lifecycle) ───────────────────────
model CompanySubscription {
  id                     String                    @id @default(uuid()) @db.Uuid
  companyId              String                    @unique @map("company_id") @db.Uuid
  billingStatus          BillingStatus             @default(trialing) @map("billing_status")
  trialStartedAt         DateTime?                 @map("trial_started_at")
  trialEndsAt            DateTime?                 @map("trial_ends_at")
  currentPeriodStart     DateTime?                 @map("current_period_start")
  currentPeriodEnd       DateTime?                 @map("current_period_end")
  graceUntil             DateTime?                 @map("grace_until")
  paymentMethod          SubscriptionPaymentMethod? @map("payment_method")
  negotiatedMonthlyPrice Decimal?                  @map("negotiated_monthly_price") @db.Decimal(12, 2)
  includedSeats          Int                       @default(5) @map("included_seats")
  perSeatPriceInr        Decimal                   @default(499) @map("per_seat_price_inr") @db.Decimal(12, 2)
  basePriceMonthly       Decimal                   @default(8999) @map("base_price_monthly") @db.Decimal(12, 2)
  cashfreeSubscriptionId String?                   @map("cashfree_subscription_id") @db.VarChar(100)
  cashfreeCustomerId     String?                   @map("cashfree_customer_id") @db.VarChar(100)
  nextBillingDate        DateTime?                 @map("next_billing_date")
  suspendedAt            DateTime?                 @map("suspended_at")
  lastTrialReminderDay   Int?                      @map("last_trial_reminder_day")
  createdAt              DateTime                  @default(now()) @map("created_at")
  updatedAt              DateTime                  @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("company_subscriptions")
}

model AgencyInvite {
  id                     String    @id @default(uuid()) @db.Uuid
  token                  String    @unique @db.VarChar(64)
  agencyName             String    @map("agency_name") @db.VarChar(255)
  adminEmail             String    @map("admin_email") @db.VarChar(255)
  negotiatedMonthlyPrice Decimal?  @map("negotiated_monthly_price") @db.Decimal(12, 2)
  companyId              String?   @map("company_id") @db.Uuid
  notes                  String?   @db.Text
  emailDeliveryStatus    String    @default("pending") @map("email_delivery_status") @db.VarChar(20)
  emailLastAttemptAt     DateTime? @map("email_last_attempt_at")
  emailSentAt            DateTime? @map("email_sent_at")
  emailDeliveredAt       DateTime? @map("email_delivered_at")
  emailLastEventAt       DateTime? @map("email_last_event_at")
  emailLastEventId       String?   @map("email_last_event_id") @db.VarChar(255)
  emailMessageId         String?   @map("email_message_id") @db.VarChar(255)
  emailLastError         String?   @map("email_last_error") @db.Text
  expiresAt              DateTime  @map("expires_at")
  acceptedAt             DateTime? @map("accepted_at")
  createdById            String    @map("created_by_id") @db.Uuid
  createdAt              DateTime  @default(now()) @map("created_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([adminEmail])
  @@map("agency_invites")
}

model Payment {
  id                String                    @id @default(uuid()) @db.Uuid
  companyId         String                    @map("company_id") @db.Uuid
  subscriptionId    String?                   @map("subscription_id") @db.Uuid
  invoiceId         String?                   @map("invoice_id") @db.Uuid
  amount            Decimal                   @db.Decimal(12, 2)
  currency          String                    @default("INR") @db.VarChar(3)
  status            PaymentStatus             @default(pending)
  method            SubscriptionPaymentMethod
  cashfreeOrderId   String?                   @unique @map("cashfree_order_id") @db.VarChar(100)
  cashfreePaymentId String?                   @map("cashfree_payment_id") @db.VarChar(100)
  metadata          Json                      @default("{}")
  paidAt            DateTime?                 @map("paid_at")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  company      Company              @relation(fields: [companyId], references: [id])
  subscription CompanySubscription? @relation(fields: [subscriptionId], references: [id])
  invoice      Invoice?             @relation(fields: [invoiceId], references: [id])

  @@index([companyId, status])
  @@map("payments")
}

model BillingEvent {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  eventType String   @map("event_type") @db.VarChar(50)
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@map("billing_events")
}

// ─── Leads (CRM) ───────────────────────────────────────────────────
model Lead {
  id                  String       @id @default(uuid()) @db.Uuid
  companyId           String       @map("company_id") @db.Uuid
  customerName        String?      @map("customer_name") @db.VarChar(255)
  phone               String       @db.VarChar(20)
  email               String?      @db.VarChar(255)
  budgetMin           Decimal?     @map("budget_min") @db.Decimal(14, 2)
  budgetMax           Decimal?     @map("budget_max") @db.Decimal(14, 2)
  locationPreference  String?      @map("location_preference") @db.VarChar(255)
  propertyType        PropertyType? @map("property_type")
  source              LeadSource   @default(whatsapp)
  status              LeadStatus   @default(new)
  assignedAgentId     String?      @map("assigned_agent_id") @db.Uuid
  notes               String?      @db.Text
  language            String       @default("en") @db.VarChar(5)
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  lastContactAt       DateTime?    @map("last_contact_at")
  /// Tracks last time an automated re-engagement message was sent (to prevent spam)
  reEngagementSentAt  DateTime?    @map("re_engagement_sent_at")
  /// Number of re-engagement messages sent to this lead
  reEngagementCount   Int          @default(0) @map("re_engagement_count")
  /// Extensible CRM fields: lead_score (hot|warm|cold), tags[], source_detail, lost_reason
  metadata            Json         @default("{}")
  /// Centralized AI memory blob — last known intent, projects discussed, budget,
  /// conversation summary, and open questions. Written by leadMemory.service.ts.
  leadMemory          Json?        @map("lead_memory")

  company         Company       @relation(fields: [companyId], references: [id])
  assignedAgent   User?         @relation("AgentLeads", fields: [assignedAgentId], references: [id])
  conversations   Conversation[]
  visits          Visit[]

  @@index([companyId, status])
  @@index([companyId, assignedAgentId])
  @@index([phone])
  @@index([companyId, lastContactAt])
  // Chunk-06: analytics dashboard 'leads today' query — companyId + createdAt filter.
  @@index([companyId, createdAt])
  /// Prevent duplicate leads for the same phone number within a company.
  /// Handles concurrent webhook retries that both try to create a new lead.
  @@unique([companyId, phone])
  @@map("leads")
}

// ─── Conversations ──────────────────────────────────────────────────
model Conversation {
  id             String             @id @default(uuid()) @db.Uuid
  companyId      String             @map("company_id") @db.Uuid
  leadId         String?            @map("lead_id") @db.Uuid
  whatsappPhone  String             @map("whatsapp_phone") @db.VarChar(20)
  status         ConversationStatus @default(ai_active)
  language       String             @default("en") @db.VarChar(5)
  aiEnabled      Boolean            @default(true) @map("ai_enabled")
  
  // Goal-directed conversation state machine
  stage          ConversationStage  @default(rapport)
  stageEnteredAt DateTime           @default(now()) @map("stage_entered_at")
  stageMessageCount Int             @default(0) @map("stage_message_count")
  
  // Micro-commitments tracking (JSON for flexibility)
  commitments    Json               @default("{}") @map("commitments")
  
  // Objection tracking
  objectionCount Int                @default(0) @map("objection_count")
  lastObjectionType String?         @map("last_objection_type") @db.VarChar(50)
  consecutiveObjections Int         @default(0) @map("consecutive_objections")
  
  // Scoring
  urgencyScore   Int                @default(5) @map("urgency_score")
  valueScore     Int                @default(5) @map("value_score")
  
  // Escalation
  escalationReason String?          @map("escalation_reason") @db.Text
  escalatedAt    DateTime?          @map("escalated_at")
  
  // Property tracking
  recommendedPropertyIds Json       @default("[]") @map("recommended_property_ids")
  selectedPropertyId String?        @map("selected_property_id") @db.Uuid
  proposedVisitTime DateTime?       @map("proposed_visit_time")
  
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  company   Company   @relation(fields: [companyId], references: [id])
  lead      Lead?     @relation(fields: [leadId], references: [id])
  messages  Message[]

  @@index([companyId])
  @@index([whatsappPhone])
  /// Index on leadId to efficiently retrieve all conversations for a lead.
  @@index([leadId])
  @@map("conversations")
}

// ─── Messages ───────────────────────────────────────────────────────
model Message {
  id                String        @id @default(uuid()) @db.Uuid
  conversationId    String        @map("conversation_id") @db.Uuid
  senderType        SenderType    @map("sender_type")
  content           String        @db.Text
  language          String?       @db.VarChar(5)
  whatsappMessageId String?       @map("whatsapp_message_id") @db.VarChar(255)
  deliveryStatus    String?       @map("delivery_status") @db.VarChar(50)
  metaMessageId     String?       @map("meta_message_id") @db.VarChar(255)
  failedReason      String?       @map("failed_reason") @db.Text
  status            MessageStatus @default(sent)
  /// INVESTO-FIX-2026-07-01: structured media fields so image/document/interactive
  /// messages can be rendered natively instead of collapsing into a text summary.
  messageType       String        @default("text") @map("message_type") @db.VarChar(20)
  mediaUrl          String?       @map("media_url") @db.Text
  mimeType          String?       @map("mime_type") @db.VarChar(100)
  mediaCaption      String?       @map("media_caption") @db.Text
  createdAt         DateTime      @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
  /// Unique constraint prevents duplicate processing of the same WhatsApp message.
  /// Handles Meta's at-least-once delivery guarantees (webhook retries).
  @@unique([whatsappMessageId])
  @@map("messages")
}

/// Cross-instance idempotency for inbound WhatsApp webhooks (Meta retries, dual providers).
