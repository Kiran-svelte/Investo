# Environment
NODE_ENV=development
PORT=3001

# Database (Supabase)
# Runtime: transaction pooler (port 6543). Migrations/direct: session pooler (port 5432).
# Pooler host is region-specific — copy from Supabase Dashboard → Database → Connection string.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_PROJECT_REF=PROJECT_REF
DB_AUTO_MIGRATE=true
DB_AUTO_SEED=true
DB_POOL_MIN=10
DB_POOL_MAX=50

# Neon Auth (optional legacy — app auth still uses JWT + password_hash today)
NEON_AUTH_URL=https://ep-example.neonauth.<region>.aws.neon.tech/DB_NAME/auth
NEON_KEEPALIVE_ENABLED=false
NEON_KEEPALIVE_INTERVAL_MS=240000

# Redis
REDIS_URL=redis://localhost:6379

# JWT
# Required outside test. Generate a unique secret per environment.
JWT_SECRET=replace-with-a-unique-jwt-secret
JWT_EXPIRES_IN=24h
# Required outside test. Generate a unique refresh secret per environment.
JWT_REFRESH_SECRET=replace-with-a-unique-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# WhatsApp Cloud API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-app-secret-for-signature-verification
WHATSAPP_ACCESS_TOKEN=your-whatsapp-business-access-token

# WhatsApp Security
WHATSAPP_IP_WHITELIST_ENABLED=true
SKIP_IP_WHITELIST=false
WHATSAPP_WEBHOOK_MAX_SIZE=1mb
WHATSAPP_DEDUP_TTL_SECONDS=300

# AI Provider
AI_PROVIDER=kimi
KIMI_API_BASE_URL=https://api.moonshot.ai/v1
KIMI_API_KEY=your-kimi-api-key
# Explicit Kimi 2.5 default model.
KIMI_2_5_MODEL=kimi-k2-2504
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=your-openai-api-key-fallback
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Set false on production when OPENAI_API_KEY is valid (use sync-render-openai-env.mjs)
PROPERTY_KNOWLEDGE_LOCAL_EMBEDDINGS=false
# Publish/import only succeeds when vector knowledge is indexed (set false to disable)
REQUIRE_PROPERTY_KNOWLEDGE_INDEX=true
# When AWS keys exist, block publish if media landed in DB blob storage
REQUIRE_CLOUD_STORAGE_ON_PUBLISH=true
OPENAI_MODEL=gpt-4o-mini

# File Storage
STORAGE_PROVIDER=aws
# AWS S3 (primary) — Stockholm bucket
AWS_REGION=eu-north-1
AWS_S3_BUCKET=biginvesto-668764275363-eu-north-1-an
AWS_S3_PREFIX=investo
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=
# One-time admin creds for scripts/provision-investo-aws-storage.mjs (do not commit)
# AWS_ADMIN_ACCESS_KEY_ID=
# AWS_ADMIN_SECRET_ACCESS_KEY=
# Optional: override the S3-compatible endpoint (useful for MinIO / Backblaze B2 / other providers).
# When set, R2_ACCOUNT_ID is not required.
# Example (MinIO): https://minio.yourdomain.com
# Example (Backblaze B2 S3): https://s3.us-west-002.backblazeb2.com
# NOTE (Backblaze B2): set R2_REGION to the bucket region (e.g. us-west-002). Do NOT leave it as "auto".
# Mapping (Backblaze B2):
#   R2_ACCESS_KEY_ID = Application Key ID
#   R2_SECRET_ACCESS_KEY = Application Key
# Security: do NOT use a Backblaze Master Application Key here. Create a bucket-restricted Application Key with only the permissions you need.
R2_ENDPOINT=
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=investo-files
R2_REGION=auto
# Public HTTPS base URL used to build stable file links.
# For Backblaze B2, a public download URL often looks like:
#   https://fxxxx.backblazeb2.com/file/<your-bucket-name>/
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev
PROPERTY_UPLOAD_MAX_BYTES=52428800
PROPERTY_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4
# R2 presigned PUT is default. Set true only for emergency DB blob uploads.
PROPERTY_IMPORT_DB_UPLOAD=false
# Public backend URL for browser upload fallback (Render: https://your-service.onrender.com)
API_PUBLIC_BASE_URL=
# Supabase Storage fallback + AI knowledge (service role — Render only, never commit)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROPERTY_BUCKET=property-media
SUPABASE_AI_KNOWLEDGE_BUCKET=ai-knowledge

# CORS
CORS_ORIGINS=http://localhost:3000

# Frontend URL used for backend-generated links (password reset, etc.)
FRONTEND_BASE_URL=http://localhost:3000

# Email for transactional emails (password reset, invites, etc.) — Resend
RESEND_API_KEY=
MAIL_FROM="Investo <onboarding@resend.dev>"
# Production: verify your domain in Resend dashboard, then use e.g.:
# MAIL_FROM="Investo <no-reply@biginvesto.online>"

# Rate Limiting
RATE_LIMIT_USER=100
RATE_LIMIT_COMPANY=1000
RATE_LIMIT_USER_AI=40
RATE_LIMIT_COMPANY_AI=120
RATE_LIMIT_WEBHOOK=300
RATE_LIMIT_SENSITIVE=10

# AI provider order: openai (default) | kimi | claude — OpenAI is tried first when OPENAI_API_KEY is set
AI_PROVIDER=openai

# Agent AI (WhatsApp-first assistant for internal users)
AGENT_AI_ENABLED=true
AGENT_AI_PROVIDER=openai
AGENT_AI_MODEL=gpt-4o-mini
AGENT_AI_MAX_TOOL_CALLS=10
AGENT_AI_THREAD_TTL_HOURS=24
AGENT_AI_CONFIRMATION_TTL_MINUTES=5
AGENT_AI_MESSAGE_WINDOW=20
AGENT_AI_CRON_ENABLED=true
AGENT_AI_TEMPERATURE=0.1
