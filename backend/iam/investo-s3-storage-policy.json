{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InvestoPropertyMediaObjects",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:HeadObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::biginvesto-668764275363-eu-north-1-an/investo/*"
    },
    {
      "Sid": "InvestoPropertyMediaList",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::biginvesto-668764275363-eu-north-1-an",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["investo/*"]
        }
      }
    }
  ]
}
